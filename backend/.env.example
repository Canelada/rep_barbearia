TWILIO_AUTH_TOKEN=seu_auth_token_twilio

# Número do WhatsApp Sandbox Twilio (formato: +14155238886)
# Para produção, use seu número aprovado pelo WhatsApp Business
TWILIO_WHATSAPP_NUMBER=+14155238886

# Nome da barbearia (exibido nas mensagens do bot)
